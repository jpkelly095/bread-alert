<%= form_with(model: bake.persisted? ? @bake : [@recipe, @bake]) do |form| %>
  <% if bake.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(bake.errors.count, "error") %> prohibited this bake from being saved:</h2>

      <ul>
        <% bake.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :baked_on, style: "display: block" %>
    <%= form.date_field :baked_on %>
  </div>

  <div>
    <%= form.label :total_weight, "Total Weight (g)", style: "display: block" %>
    <%= form.number_field :total_weight %>
  </div>

  <div>
    <%= form.label :container_id, style: "display: block" %>
    <%= form.collection_select :container_id, Container.all, :id, :name, { prompt: "Select Container" } %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
